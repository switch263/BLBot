# Discord Bot Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Required: Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Optional: Guild ID for instant slash command sync (right-click server -> Copy Server ID)
# Without this, slash commands can take up to an hour to appear after changes
DISCORD_GUILD_ID=
